{
  "name": "scratchpad-cloudflare",
  "private": true,
  "type": "module",
  "description": "Cloudflare-native deployment of Scratchpad: Pages Functions + R2 + D1",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "wrangler pages dev ../web/dist",
    "deploy": "wrangler pages deploy ../web/dist",
    "schema": "wrangler d1 execute scratchpad --file schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
