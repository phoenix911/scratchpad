# Copy to .env and fill in. Real env vars override these.
PORT=8080
SHARE_BASE_URL=https://slate.example.com

# Single-password gate (hashed in memory at boot).
SLATE_PASSWORD=

# Git sync — leave blank to run local-only (sync off).
GIT_URL=
GIT_USER=
GIT_PAT=

# Optional paths
DATA_DIR=./data
DB_PATH=./app.db

# Optional branding
APP_NAME=Slate
