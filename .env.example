# Copy to .env and fill in. Real environment variables override these.

# Port the server listens on.
PORT=8080
# Bind address. Empty = all interfaces; set 127.0.0.1 when behind a reverse proxy/tunnel.
BIND=

# Public URL the app is reachable at (used to build share links). Optional.
SHARE_BASE_URL=https://scratchpad.example.com

# Single-password gate. Leave blank to run with no auth (local only).
SCRATCHPAD_PASSWORD=

# Git sync of the data directory — leave GIT_URL blank to run local-only (sync off).
# SSH URL (git@host:owner/repo.git) uses the machine's SSH key; HTTPS needs GIT_PAT.
GIT_URL=
GIT_USER=
GIT_PAT=
# Commit identity for the data repo (defaults: scratchpad / scratchpad@local).
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# Optional paths.
DATA_DIR=./data
DB_PATH=./scratchpad.db

# Optional branding (tab title / header).
APP_NAME=Scratchpad
