# secrets & local config — never commit
.env
what_i_need
cloudflare_api_keys

# cloudflare deploy: local deps + wrangler state
/cloudflare/node_modules/
/cloudflare/.wrangler/
/cloudflare/.dev.vars

# rebuildable SQLite index
scratchpad.db
scratchpad.db-*
app.db
app.db-*

# the git-synced content lives in its OWN repo, not this source repo
/data/

# build artifacts
/scratchpad
/scratchpad-linux-arm64
/slate
/slate-linux-arm64
/web/dist/
/web/node_modules/
/web/*.tsbuildinfo

# misc
.DS_Store
*.log

# local screenshots
/web/.shots/

# cross-compile output + staged box env (has secrets)
/dist/
scratchpad-linux-amd64
